# Copy these names into the hosting provider's environment-variable settings.
# Never commit a real secret key.
OPENAI_API_KEY=

# Optional: choose a supported JSON-capable chat model available to the account.
OPENAI_MODEL=gpt-4o-mini

# Optional: comma-separated additional browser origins allowed to call the API.
# Same-origin requests from the deployed site work automatically.
APP_ORIGIN=https://your-exposure-project.vercel.app
